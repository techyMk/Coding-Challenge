//Problem Link: https://leetcode.com/problems/reorder-routes-to-make-all-paths-lead-to-the-city-zero/

class Solution {
public:
    int dfs(int node, vector<vector<pair<int,int>>>& adj, vector<bool>& visited) {
        visited[node]=true;
        int changes=0;
        for(auto &it:adj[node]) {
            int neighbor=it.first;
            int cost=it.second;
            if(!visited[neighbor]) {
                changes+=cost+dfs(neighbor, adj, visited);
            }
        }
        return changes;
    }
    int minReorder(int n, vector<vector<int>>& connections) {
        vector<vector<pair<int,int>>> adj(n);
        for(auto &c:connections) {
            int u=c[0];
            int v=c[1];
            adj[u].push_back({v,1}); 
            adj[v].push_back({u,0}); 
        }
        vector<bool> visited(n,false);
        return dfs(0, adj, visited);
    }
};
